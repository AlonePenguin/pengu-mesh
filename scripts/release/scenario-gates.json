{
  "schema_version": "scenario-gate-manifest.v1",
  "default_limit": 25,
  "gates": [
    {
      "name": "startup-readiness-release",
      "family": "startup-readiness",
      "limit": 10,
      "min_runs": 1,
      "allowed_statuses": ["passed"],
      "max_assertion_failures": 0,
      "min_samples_per_metric": 1,
      "thresholds": [
        {
          "name": "startup-health",
          "metric": "health",
          "max_ms": 5000,
          "p50_ms": 5000
        }
      ]
    },
    {
      "name": "operator-diagnosis-release",
      "family": "operator-diagnosis",
      "limit": 10,
      "min_runs": 1,
      "allowed_statuses": ["passed"],
      "max_assertion_failures": 0,
      "min_samples_per_metric": 1,
      "thresholds": [
        {
          "name": "operator-diagnose",
          "metric": "diagnose",
          "max_ms": 5000,
          "p50_ms": 5000
        },
        {
          "name": "operator-health",
          "metric": "health",
          "max_ms": 5000,
          "p50_ms": 5000
        }
      ]
    },
    {
      "name": "structured-failure-release",
      "family": "structured-failure",
      "limit": 10,
      "min_runs": 1,
      "allowed_statuses": ["passed"],
      "max_assertion_failures": 0,
      "min_samples_per_metric": 1,
      "thresholds": [
        {
          "name": "structured-missing-instance",
          "metric": "missing-instance",
          "max_ms": 5000,
          "p50_ms": 5000
        }
      ]
    }
  ]
